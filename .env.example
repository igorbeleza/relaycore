# Network
HOST=127.0.0.1
PORT=47822

# Runtime
NODE_ENV=development
LOG_LEVEL=info

# Upstream Anthropic-compatible provider
#
# UPSTREAM_MODE selects how requests are authenticated upstream:
#   provider    - RelayCore holds UPSTREAM_API_KEY and replaces the client key.
#                 Requires UPSTREAM_API_KEY. Default base URL: https://api.oneprovider.dev
#   passthrough - RelayCore forwards the client's own authorization / x-api-key
#                 headers upstream. UPSTREAM_API_KEY must be empty.
#                 Default base URL: https://api.anthropic.com
# If unset, the mode is inferred: provider when UPSTREAM_API_KEY is set,
# passthrough otherwise.
UPSTREAM_MODE=
UPSTREAM_BASE_URL=
UPSTREAM_API_KEY=
UPSTREAM_TIMEOUT_MS=120000

# Maximum accepted request body size, in bytes. Requests larger than this are
# rejected with HTTP 413 before parsing. Default: 20971520 (20 MiB).
MAX_REQUEST_BODY_BYTES=20971520

# Local diagnostics
# Not a boolean — this is a secret token (min 16 chars) that both enables and
# authenticates GET /debug/last-error and GET /debug/errors. Empty/unset (the
# default) means those routes 404 as if they don't exist. Do NOT set a fixed
# value here in shared/example config: generate your own random value locally,
# e.g. `node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"`,
# and put it only in your untracked .env. Requests must send it back via
# `Authorization: Bearer <token>` or `x-relaycore-debug-token: <token>`.
DEBUG_TOKEN=

# pxpipe: convert large text blocks to PNG images before forwarding (see README)
PXPIPE_ENABLED=true
PXPIPE_MIN_CHARS=4000
PXPIPE_SAVINGS_FACTOR=0.7
PXPIPE_MAX_PAGES_PER_BLOCK=4
PXPIPE_KEEP_RECENT_TURNS=3
PXPIPE_SCOPE=user_and_tool_results

# dedup: remove byte-for-byte duplicate content blocks within a single request,
# keeping the first occurrence and replacing later ones with a short backward
# reference. Runs before pxpipe. (see README)
DEDUP_ENABLED=true
DEDUP_MIN_CHARS=500
DEDUP_SCOPE=user_and_tool_results
DEDUP_KEEP_RECENT_TURNS=0
